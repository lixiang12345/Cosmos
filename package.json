{
  "name": "cosmos-agent-platform",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "pnpm dev:runtime",
    "dev:demo": "AUTH_MODE=development VITE_AUTH_MODE=development VITE_DEMO_MODE=true pnpm --parallel --filter @cosmos/api --filter @cosmos/web dev",
    "dev:web": "VITE_AUTH_MODE=development VITE_DEMO_MODE=true pnpm --filter @cosmos/web dev",
    "dev:api": "AUTH_MODE=development pnpm --filter @cosmos/api dev",
    "dev:worker": "pnpm --filter @cosmos/api dev:worker",
    "dev:runtime": "docker compose up --build --wait",
    "runtime:down": "docker compose down",
    "runtime:logs": "docker compose logs -f api worker web",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @cosmos/api migrate",
    "db:backup": "sh ops/postgres/backup.sh",
    "db:restore": "sh ops/postgres/restore.sh",
    "db:pitr-preflight": "sh ops/postgres/pitr-preflight.sh",
    "object-storage:gc": "pnpm --filter @cosmos/api object-storage:gc",
    "load:smoke": "node ops/load/http-smoke.mjs",
    "soak:session": "node ops/load/session-journey.mjs",
    "drill:worker-readiness": "sh ops/drills/worker-readiness.sh",
    "drill:database-readiness": "sh ops/drills/database-readiness.sh",
    "metrics:database": "node ops/observability/database-metrics.mjs",
    "test:ops": "sh -n ops/postgres/backup.sh ops/postgres/restore.sh ops/postgres/pitr-preflight.sh ops/drills/worker-readiness.sh ops/drills/database-readiness.sh && node --test ops/load/*.test.mjs ops/observability/*.test.mjs",
    "test:integration": "pnpm --filter @cosmos/api test:integration",
    "build": "pnpm --filter @cosmos/contracts build && pnpm --filter @cosmos/api build && pnpm --filter @cosmos/web build",
    "lint": "eslint .",
    "openapi:lint": "redocly lint docs/api-contract.yaml",
    "openapi:bundle": "redocly bundle docs/api-contract.yaml --output dist/api-contract.yaml",
    "test": "pnpm --filter @cosmos/contracts build && pnpm --recursive --if-present test",
    "typecheck": "pnpm --filter @cosmos/contracts build && pnpm --recursive --if-present typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:ops && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@redocly/cli": "2.38.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
