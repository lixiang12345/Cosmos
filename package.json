{
  "name": "relay-agent-platform",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "AUTH_MODE=development VITE_AUTH_MODE=development VITE_DEMO_MODE=true pnpm --parallel --filter @relay/api --filter @relay/web dev",
    "dev:web": "VITE_AUTH_MODE=development VITE_DEMO_MODE=true pnpm --filter @relay/web dev",
    "dev:api": "AUTH_MODE=development pnpm --filter @relay/api dev",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @relay/api migrate",
    "test:integration": "pnpm --filter @relay/api test:integration",
    "build": "pnpm --filter @relay/contracts build && pnpm --filter @relay/api build && pnpm --filter @relay/web build",
    "lint": "eslint .",
    "test": "pnpm --filter @relay/contracts build && pnpm --recursive --if-present test",
    "typecheck": "pnpm --filter @relay/contracts build && pnpm --recursive --if-present typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
