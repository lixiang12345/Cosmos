# API runtime
NODE_ENV=development
AUTH_MODE=development
PORT=8787
HOST=127.0.0.1
# Only set this for a local container network; never use it outside NODE_ENV=development.
ALLOW_NON_LOOPBACK_DEVELOPMENT_AUTH=false
# Comma-separated trusted reverse-proxy IP/CIDR entries. Never use a wildcard.
TRUST_PROXY=
API_BODY_LIMIT_BYTES=1048576
API_CONNECTION_TIMEOUT_MS=10000
API_REQUEST_TIMEOUT_MS=15000
API_KEEP_ALIVE_TIMEOUT_MS=5000
# Per-API-instance abuse boundary. Production still requires an edge/global limiter.
API_RATE_LIMIT_MAX=600
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_CACHE=10000
# Optional ContextEngine-plugin Relay gateway. Configure all three values together.
CONTEXT_ENGINE_BASE_URL=http://127.0.0.1:8790
CONTEXT_ENGINE_API_KEY=
CONTEXT_ENGINE_WORKSPACES_JSON={"relay/platform":"workspace-platform"}
CONTEXT_ENGINE_TIMEOUT_MS=20000
# Required only for development HTTP endpoints outside the API container's loopback interface.
CONTEXT_ENGINE_ALLOW_INSECURE_HTTP=false
# 32-byte hex HMAC key from Secret Manager; required in staging/production.
SECURITY_AUDIT_HMAC_KEY=
# Stable non-secret identifier retained with audit rows to support key rotation.
SECURITY_AUDIT_HMAC_KEY_ID=
# Optional server-side bearer credential for the internal Prometheus scrape endpoint.
METRICS_SCRAPE_TOKEN=
DATABASE_URL=postgres://relay:relay-local-only@127.0.0.1:55432/relay
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_QUERY_TIMEOUT_MS=20000
DATABASE_STATEMENT_TIMEOUT_MS=15000
# Development defaults to true. Staging/production must run `pnpm db:migrate` as a separate job.
MIGRATE_ON_START=true
# Development may enable protocol-1 execution. Staging/production defaults to disabled.
EXECUTION_ENABLED=true
EXECUTION_MAX_ATTEMPTS=5
# Per-API-instance SSE connection budgets. All values are strictly bounded at startup.
SESSION_EVENT_STREAM_MAX_CONNECTIONS=1000
SESSION_EVENT_STREAM_MAX_CONNECTIONS_PER_ACTOR=10
SESSION_EVENT_STREAM_MAX_CONNECTIONS_PER_SESSION=50
SESSION_EVENT_STREAM_RETRY_AFTER_SECONDS=5
# Worker-only settings. Use a real secret manager outside local development.
WORKER_ID=worker-local-1
WORKER_LEASE_DURATION_MS=30000
WORKER_HEARTBEAT_INTERVAL_MS=8000
# Shared by the API capability gate and Worker container health check.
WORKER_READINESS_MAX_AGE_MS=30000
WORKER_POLL_INTERVAL_MS=500
WORKER_RECOVERY_BATCH_SIZE=20
AGENT_PROVIDER_BASE_URL=https://api.247kan.com/v1/
# Optional compatibility fallback. Prefer the three family-specific Secret Manager values.
AGENT_PROVIDER_API_KEY=
AGENT_PROVIDER_GPT_API_KEY=local-gpt-development-token
AGENT_PROVIDER_CLAUDE_API_KEY=local-claude-development-token
AGENT_PROVIDER_GROK_API_KEY=local-grok-development-token
AGENT_PROVIDER_CONNECTION_TIMEOUT_MS=10000
AGENT_PROVIDER_TOTAL_TIMEOUT_MS=120000
AGENT_PROVIDER_MAX_OUTPUT_TOKENS=4096
AGENT_PROVIDER_MAX_OUTPUT_CHARACTERS=100000
AGENT_PROVIDER_MAX_RESPONSE_BYTES=1048576
CORS_ORIGIN=http://127.0.0.1:5173
OIDC_ISSUER=https://identity.example.com/
OIDC_AUDIENCE=relay-api
OIDC_JWKS_URI=https://identity.example.com/.well-known/jwks.json

# Local development only; ignored when OIDC is configured.
DEVELOPMENT_ACTOR_ID=user-local-admin

# Web development proxy
VITE_API_PROXY_TARGET=http://127.0.0.1:8787
VITE_AUTH_MODE=development
VITE_DEMO_MODE=true
VITE_DEVELOPMENT_ACTOR_ID=user-local-admin
# Compose sets this only for its loopback production bundle. Leave false elsewhere.
VITE_ALLOW_PRODUCTION_DEVELOPMENT_AUTH=false

# Production Web OIDC (required when VITE_AUTH_MODE=oidc)
VITE_OIDC_AUTHORITY=https://identity.example.com/
VITE_OIDC_CLIENT_ID=relay-web
VITE_OIDC_AUDIENCE=relay-api
VITE_OIDC_SCOPE=openid profile email
VITE_OIDC_REDIRECT_URI=https://relay.example.com/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://relay.example.com/
VITE_OIDC_SILENT_REDIRECT_URI=https://relay.example.com/auth/silent-callback
# Optional only when the browser API is cross-origin. Entries are comma-separated HTTPS origins.
VITE_API_ALLOWED_ORIGINS=https://api.relay.example.com
