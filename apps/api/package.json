{
  "name": "@relay/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx --env-file-if-exists=../../.env.local watch src/worker.ts",
    "build": "tsup src/index.ts src/server.ts src/worker.ts src/worker-health.ts src/migrate.ts --format esm --dts --clean",
    "migrate": "tsx src/migrate.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "health:worker": "node dist/worker-health.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "13.1.0",
    "@relay/contracts": "workspace:*",
    "fastify": "^5.6.2",
    "jose": "^6.2.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
